// File-backed development helpers.
//
// This example is for the "I computed/downloaded something once, now I want to
// reuse it in later evals" workflow. There is no hidden REPL state here:
// values are saved to ordinary files, then later eval calls read those files.
(package main)
(import "core:fmt")
(import json "core:encoding/json")
(import os "core:os")

(struct Note {
  :title string
  :body string
})

(struct Count {
  :n int
})

// The examples below write under ./tmp. Odin's write helpers do not create
// parent directories, so production code should create the directory first or
// surface that error. Here we keep the directory policy explicit and boring.
(proc ensure-dev-dir [] -> os.Error
  (let [err (os.make_directory_all "tmp")]
    (if (and (!= err nil)
             (not (os.is_directory "tmp")))
      err
      nil)))

(proc write-text [path: string, text: string] -> os.Error
  (let [dir-err (ensure-dev-dir)]
    (if (!= dir-err nil)
      dir-err
      (spit path text))))

(proc read-text [path: string] -> [data: []byte, err: os.Error]
  ;; Ownership of data transfers to the caller.
  (slurp path))

(proc write-as-json [path: string, value: $T] -> [marshal-err: json.Marshal_Error, write-err: os.Error]
  (let [dir-err (ensure-dev-dir)]
    (if (!= dir-err nil)
      (return marshal-err dir-err)
      (let [[data err] (json.marshal value)]
        (if (!= err nil)
          (return err write-err)
          (do
            (defer (delete data))
            (return nil (spit path data))))))))

(proc read-json-as [$T: typeid, path: string] -> [value: T, read-err: os.Error, unmarshal-err: json.Unmarshal_Error]
  (let [[data err] (slurp path)]
    (if (!= err nil)
      (return value err unmarshal-err)
      (do
        (defer (delete data))
        (let [decode-err (json.unmarshal data (& value))]
          (return value nil decode-err))))))

(proc main []
  (return))

(comment
  ;; These forms are meant for editor eval. They deliberately use real files,
  ;; so the result survives across separate kvist eval processes.

  (ensure-dev-dir)
  ;; => nil

  ;; Text files use a small ordinary helper pair. read-text returns owned bytes,
  ;; so delete the bytes directly in the same scope that reads them.
  (write-text "tmp/kvist-note.txt" "hello")
  ;; => nil

  (let [[data err] (read-text "tmp/kvist-note.txt")]
    (if (!= err nil)
      ""
      (do
        (defer (delete data))
        (string data))))
  ;; => hello

  ;; JSON is useful for typed cached dev data, but it is not Kvist core syntax.
  ;; write-as-json and read-json-as are ordinary generic procs in this file:
  ;; they call json.marshal and json.unmarshal explicitly, then use spit/slurp
  ;; for file IO. json.unmarshal allocates Note's decoded string fields, so
  ;; delete those fields directly in the same scope that reads them.
  (let [[marshal-err write-err] (write-as-json
                                  "tmp/kvist-note.json"
                                  (Note {:title "hello" :body "from Kvist"}))]
    (and (== marshal-err nil)
         (== write-err nil)))
  ;; => true

  (let [[note read-err unmarshal-err] (read-json-as Note "tmp/kvist-note.json")]
    (if (or (!= read-err nil)
            (!= unmarshal-err nil))
      false
      (do
        (defer (delete (:title note)))
        (defer (delete (:body note)))
        (fmt.println note)
        true)))
  ;; prints the parsed Note struct, then returns true

  (let [[marshal-err write-err] (write-as-json "tmp/kvist-count.json" (Count {:n 42}))]
    (and (== marshal-err nil)
         (== write-err nil)))
  ;; => true

  (let [[count read-err unmarshal-err] (read-json-as Count "tmp/kvist-count.json")]
    (if (or (!= read-err nil)
            (!= unmarshal-err nil))
      0
      (:n count)))
  ;; => 42
)
