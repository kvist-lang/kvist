// Exercises tagged union construction and narrow type-switch handling.
(package main)
(import "core:fmt")

(union Value {
  :i int
  :s string
})

(proc describe [value: Value] -> string
  (switch [v value]
    int "int"
    string v
    :else "nil"))

(proc main []
  (let [number (Value {:i 42})
        text (Value {:s "odinl"})]
    (fmt.println (describe text))))

(comment
  (describe (Value {:i 42}))
  ;; => int

  (describe (Value {:s "odinl"}))
  ;; => odinl
)
