// Port of the Cluck reset multi-return demo.
(package main)
(defn half-and-ok [x: :int] -> [value: :int, ok: :bool]
  (return (/ x 2) true))

(defn multi-return-demo [] -> :int
  (let [[value ok] (half-and-ok 10)]
    (if ok
      value
      0)))

(defn main []
  (println (multi-return-demo)))

(comment
  (multi-return-demo)
  ;; => 5
)
