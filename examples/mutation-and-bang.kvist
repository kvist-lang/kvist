// Exercises struct field updates, pointer mutation, and in-place sequence helpers.
(package main)
(import arr "kvist:arr")

(defstruct Order {
  :id int
  :amount int
  :discount int
  :status int
})

(defn settled? [order: Order] -> bool
  (== (:status order) 3))

(defn settle-order [order: Order] -> Order
  (let [updated order]
    (when (and (== (:status updated) 2)
               (> (:amount updated) 100))
      (update! updated :amount (- (:amount updated) (:discount updated)))
      (update! updated :discount 0)
      (update! updated :status 3))
    updated))

(defn settle-order! [order: ^Order]
  ;; Use a pointer parameter when the caller expects in-place mutation of the
  ;; shared order value rather than a returned copy.
  (when (and (== (:status (deref order)) 2)
             (> (:amount (deref order)) 100))
    (update! order^ :amount (- (:amount order^) (:discount order^)))
    (update! order^ :discount 0)
    (update! order^ :status 3)))

(defn order-score [orders: []Order] -> int
  (let [total 0]
    (each [order orders]
      (set! total (+ total (:amount order)))
      (set! total (+ total (:status order))))
    total))

(defn sample-orders [] -> [dynamic]Order
  (arr/dynamic Order [(Order {:id 1 :amount 80 :discount 5 :status 1})
                      (Order {:id 2 :amount 250 :discount 20 :status 2})
                      (Order {:id 3 :amount 140 :discount 10 :status 2})
                      (Order {:id 4 :amount 90 :discount 0 :status 3})]))

(defn map-bang-score [] -> int
  (let [orders (sample-orders)]
    (defer (delete orders))
    (map! settle-order orders)
    (order-score (slice orders))))

(defn filter-bang-count [] -> int
  (let [orders (sample-orders)]
    (defer (delete orders))
    (map! settle-order orders)
    (filter! settled? orders)
    (count orders)))

(defn pointer-update-score [] -> int
  (let [orders (sample-orders)]
    (defer (delete orders))
    (each [_ idx orders]
      (settle-order! (addr (get orders idx))))
    (order-score (slice orders))))

(defn main []
  (println (map-bang-score))
  (println (filter-bang-count))
  (println (pointer-update-score)))

(comment
  ;; map! replaces each struct value with the returned updated struct.
  (map-bang-score)
  ;; => 513

  ;; filter! compacts a dynamic array after mutation.
  (filter-bang-count)
  ;; => 3

  ;; Pointer-style updates mutate fields on array elements directly.
  (pointer-update-score)
  ;; => 513
)
