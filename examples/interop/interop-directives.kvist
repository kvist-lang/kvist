// Exercises declaration attributes, procedure directives, named returns, and flat destructuring.
(package main)

(odin "@(private)")
(odin "#force_inline")
(defn hidden-answer [] -> int
  42)

(defn query-answer [] -> [value: int, ok: bool] #optional_ok
  (return (hidden-answer) true))

(defn main []
  (let [[value ok] (query-answer)]
    (core/when ok
      (core/println value))))

(core/comment
  (hidden-answer)
  ;; => 42

  (query-answer)
  ;; => 42
)
