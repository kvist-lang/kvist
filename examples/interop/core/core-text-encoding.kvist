// Host interop with core text, parsing, encoding, and crypto packages.
//
// This file shows the ordinary Odin shape for string work: some helpers return
// plain booleans or integers, while encoding.parsing helpers may return owned
// slices plus errors. Owned slices are deleted in the same proc that consumes
// them unless ownership is deliberately returned to the caller.
(package main)
(import core "kvist:core")
(import strings "core:strings")
(import strconv "core:strconv")
(import base64 "core:encoding/base64")
(import hex "core:encoding/hex")
(import sha2 "core:crypto/sha2")

(defn useful-line? [line: string] -> bool
  (and (strings.has_prefix line "user:")
       (strings.contains line "active=true")))

(defn word-count [] -> int
  ;; strings.fields allocates the slice of string fields. We delete it before
  ;; returning because callers only need the count.
  (let [[words err] (strings.fields "  Ada  Lin   Grace  ")]
    (if (!= err nil)
      0
      (do
        (defer (delete words))
        (len words)))))

(defn parsed-score [] -> int
  (let [[value ok] (strconv.parse_int "42")]
    (if ok value 0)))

(defn base64-roundtrip-length [] -> int
  ;; base64.encode and base64.decode allocate owned []byte values. The
  ;; transmute is explicit because Odin distinguishes string from byte slices.
  (let [text "kvist"
        [encoded encode-err] (base64.encode (transmute []byte text))]
    (if (!= encode-err nil)
      0
      (do
        (defer (delete encoded))
        (let [[decoded decode-err] (base64.decode encoded)]
          (if (!= decode-err nil)
            0
            (do
              (defer (delete decoded))
              (len decoded))))))))

(defn sha256-hex-length [] -> int
  ;; sha2 uses an explicit context, update, and final call. hex.encode then
  ;; allocates the printable digest bytes, which this proc deletes locally.
  (let [text "kvist"
        ctx (sha2.Context_256 {})
        digest ([32]byte [])]
    (sha2.init_256 (addr ctx))
    (sha2.update (addr ctx) (transmute []byte text))
    (sha2.final (addr ctx) (slice digest))
    (let [[encoded err] (hex.encode (slice digest))]
      (if (!= err nil)
        0
        (do
          (defer (delete encoded))
          (len encoded))))))

(defn main []
  (println (useful-line? "user:Ada active=true")
               (word-count)
               (parsed-score)
               (base64-roundtrip-length)
               (sha256-hex-length)))

(comment
  ;; These examples are useful for learning the host APIs because the Odin
  ;; package names and result ownership are still visible at the call site.

  (useful-line? "user:Ada active=true")
  ;; => true

  (word-count)
  ;; => 3

  (parsed-score)
  ;; => 42

  (base64-roundtrip-length)
  ;; => 5

  (sha256-hex-length)
  ;; => 64
)
