// Exercises conditionals, value switches, grouped cases, loops, and name mapping.
(package main)
(import "core:fmt")

(enum Method [
  Get
  Head
  Post
  Delete
])

(proc read-method? [method: Method] -> bool
  (switch method
    [.Get .Head] true
    :else false))

(proc method-name [method: Method] -> string
  (switch method
    .Get "GET"
    .Head "HEAD"
    .Post "POST"
    :else "OTHER"))

(proc classify [n: int] -> string
  (cond
    (< n 0) "negative"
    (== n 0) "zero"
    :else "positive"))

(proc sum [xs: []int] -> int
  (let [total 0]
    (each [x xs]
      (set! total (+ total x)))
    total))

(proc lookup-method [name: string] -> [method: Method, ok: bool]
  (cond
    (== name "GET") (return .Get true)
    (== name "HEAD") (return .Head true)
    (== name "POST") (return .Post true)
    (== name "DELETE") (return .Delete true)
    :else (return .Get false)))

// when-let is a compiler-defined macro for Odin-style multi-returns with an
// explicit boolean such as ok, found, present, or valid.
(proc method-score [name: string] -> int
  (let [score 0]
    (when-let [method found (lookup-method name)]
      (when (read-method? method)
        (set! score 10)))
    score))

// if-let is the expression variant. Use it when the false branch should
// produce a value instead of just doing nothing.
(proc method-title [name: string] -> string
  (if-let [method found (lookup-method name)]
    (method-name method)
    "UNKNOWN"))

(proc main []
  (let [xs (new []int [1 2 3])]
    (fmt.println (classify (sum xs)))))

(comment
  (method-name .Get)
  ;; => GET

  (read-method? .Head)
  ;; => true

  (classify -1)
  ;; => negative

  (sum [1 2 3 4 5 6])
  ;; => 21

  (method-score "HEAD")
  ;; => 10

  (method-score "POST")
  ;; => 0

  (method-title "DELETE")
  ;; => OTHER

  (method-title "PATCH")
  ;; => UNKNOWN
)
