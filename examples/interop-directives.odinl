// Exercises declaration attributes, procedure directives, named returns, and flat destructuring.
(package main)
(import "core:fmt")

(odin "@(private)")
(odin "#force_inline")
(proc hidden-answer [] -> int
  42)

(proc query-answer [] -> [value: int, ok: bool] #optional_ok
  (return (hidden-answer) true))

(proc main []
  (let [[value ok] (query-answer)]
    (when ok
      (fmt.println value))))

(comment
  (hidden-answer)
  ;; => 42

  (query-answer)
  ;; => 42
)
