// Render a shipped html tree to an owned HTML string.
(package main)
(import html "kvist:html")

(defn render-demo [] -> bool
  (let [html (html.render
               [:div {:class "border"}
                [:button {:class "primary"} "Save & Close"]
                [:span "Status <ok>"]]) defer]
    (core.println html)
    true))

(defn main []
  (render-demo))
