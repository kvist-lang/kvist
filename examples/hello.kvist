// Greets from Kvist.
(package main)

;; This is a greeting
(defstruct Greeting {
  :message string
})

(defn main []
  (let [g (Greeting { :message "hello from kvist" })]
    (core/println (:message g))))

(core/comment

  (core/-> (Greeting { :message "hello!" })
      :message
      len)
  ;; => 6

)
