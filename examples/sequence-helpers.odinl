// Exercises additional eager sequence helpers and ownership cleanup.
(package main)
(import "core:fmt")

(proc even? [x: int] -> bool
  (== (% x 2) 0))

(proc small? [x: int] -> bool
  (< x 4))

(proc add-index [i: int, x: int] -> int
  (+ i x))

(proc add [acc: int, x: int] -> int
  (+ acc x))

(proc identity-int [x: int] -> int
  x)

(proc parity [x: int] -> int
  (% x 2))

(proc name-key [name: string] -> string
  name)

(proc next-answer [] -> int
  42)

(proc double [x: int] -> int
  (* x 2))

(proc negative [x: int] -> int
  (- x))

(proc square-even [x: int] -> [value: int, ok: bool]
  (if (even? x)
    (return (* x x) true)
    (return 0 false)))

(struct Segment {
  :values []int
})

(proc segment-values [segment: Segment] -> []int
  (:values segment))

(proc split-front-length [] -> int
  (let [xs (new []int [1 2 3 4])
        [front _] (split-at 2 xs)]
    (len front)))

(proc first-kept-square [] -> int
  (let [xs (new []int [1 2 3 4])
        kept (keep square-even xs)]
    (defer (delete kept))
    (first kept)))

(proc age-for-grace [] -> int
  (let [names (new []string ["Ada" "Lin" "Grace"])
        ages (new []int [36 17 45])
        ages-by-name (zipmap names ages)]
    (defer (delete ages-by-name))
    (get ages-by-name "Grace")))

(proc chunk-count [] -> int
  (let [xs (new []int [1 2 3 4])
        chunks (partition 2 xs)]
    (defer (delete chunks))
    (len chunks)))

(proc repeated-two-count [] -> int
  (let [xs (new []int [1 2 2 3])
        counts (frequencies xs)]
    (defer (delete counts))
    (get counts 2)))

(proc indexed-name-count [] -> int
  (let [names (new []string ["Ada" "Lin" "Grace"])
        by-name (index-by name-key names)]
    (defer (delete by-name))
    (len by-name)))

(proc even-group-count [] -> int
  (let [xs (new []int [1 2 3 4 6])
        groups (group-by parity xs)
        evens (get groups 0)]
    (defer
      (each [_ group groups]
        (delete group))
      (delete groups))
    (len evens)))

(proc range-total [] -> int
  (let [xs (range 1 5)]
    (defer (delete xs))
    (reduce add 0 xs)))

(proc repeated-answer-count [] -> int
  (let [xs (repeatedly 3 next-answer)]
    (defer (delete xs))
    (len xs)))

(proc repeated-word-last [] -> string
  (let [xs (repeat 3 "odin")]
    (defer (delete xs))
    (last xs)))

(proc iterated-last [] -> int
  (let [xs (iterate 4 double 1)]
    (defer (delete xs))
    (last xs)))

(proc cycled-total [] -> int
  (let [base (new []int [1 2 3])
        xs (cycle 5 base)]
    (defer (delete xs))
    (reduce add 0 xs)))

(proc counted-cycle [] -> int
  (let [base (new []int [1 2])
        xs (cycle 5 base)]
    (defer (delete xs))
    (count xs)))

(proc trimmed-sum [] -> int
  (let [xs (new []int [1 2 3 4 5])
        head (take 3 xs)
        tail (drop 2 xs)
        smalls (take-while small? xs)
        bigs (drop-while small? xs)]
    (+ (+ (last head) (first tail))
       (+ (len smalls) (first bigs)))))

(proc rest-second-empty-score [] -> int
  (let [xs (new []int [10 20 30])
        tail (rest xs)
        empty-tail (drop 3 xs)]
    (if (empty? empty-tail)
      (+ (first tail) (second xs))
      0)))

(proc concat-reversed-first [] -> int
  (let [xs (new []int [1 2])
        ys (new []int [3 4])
        joined (concat xs ys)
        reversed (reverse joined)]
    (defer (delete joined))
    (defer (delete reversed))
    (first reversed)))

(proc sorted-second [] -> int
  (let [xs (new []int [4 1 3 2])
        sorted (sort xs)]
    (defer (delete sorted))
    (second sorted)))

(proc descending-first [] -> int
  (let [xs (new []int [4 1 3 2])
        sorted (sort-by negative xs)]
    (defer (delete sorted))
    (first sorted)))

(proc sorted-in-place-first [] -> int
  (let [xs (new [dynamic]int [4 1 3 2])]
    (defer (delete xs))
    (sort! xs)
    (first xs)))

(proc reversed-in-place-first [] -> int
  (let [xs (new [dynamic]int [1 2 3 4])]
    (defer (delete xs))
    (reverse! xs)
    (first xs)))

(proc descending-in-place-first [] -> int
  (let [xs (new [dynamic]int [4 1 3 2])]
    (defer (delete xs))
    (sort-by! negative xs)
    (first xs)))

(proc doubled-in-place-total [] -> int
  (let [xs (new [dynamic]int [1 2 3])]
    (defer (delete xs))
    (map! double xs)
    (reduce add 0 xs)))

(proc indexed-in-place-second [] -> int
  (let [xs (new [dynamic]int [1 2 3])]
    (defer (delete xs))
    (map-indexed! add-index xs)
    (second xs)))

(proc filtered-in-place-count [] -> int
  (let [xs (new [dynamic]int [1 2 3 4])]
    (defer (delete xs))
    (filter! even? xs)
    (len xs)))

(proc removed-in-place-first [] -> int
  (let [xs (new [dynamic]int [1 2 3 4])]
    (defer (delete xs))
    (remove! even? xs)
    (first xs)))

(proc kept-in-place-first [] -> int
  (let [xs (new [dynamic]int [1 2 3 4])]
    (defer (delete xs))
    (keep! square-even xs)
    (first xs)))

(proc appended-total [] -> int
  (let [xs (new [dynamic]int [1 2])
        more (new []int [3 4])]
    (defer (delete xs))
    (into! xs more)
    (reduce add 0 xs)))

(proc distinct-total [] -> int
  (let [xs (new []int [1 2 2 3 3])
        unique (distinct xs)]
    (defer (delete unique))
    (reduce add 0 unique)))

(proc first-per-parity-count [] -> int
  (let [xs (new []int [1 3 2 4 5])
        unique (distinct-by parity xs)]
    (defer (delete unique))
    (count unique)))

(proc ragged-chunk-size [] -> int
  (let [xs (new []int [1 2 3 4 5])
        chunks (partition-all 2 xs)]
    (defer (delete chunks))
    (len (last chunks))))

(proc run-count [] -> int
  (let [xs (new []int [1 1 2 2 2 3 1])
        runs (partition-by identity-int xs)]
    (defer (delete runs))
    (len runs)))

(proc flattened-total [] -> int
  (let [segments (new []Segment [(Segment {:values (new []int [1 2])})
                                 (Segment {:values (new []int [3])})
                                 (Segment {:values (new []int [4 5])})])
        values (mapcat segment-values segments)]
    (defer (delete values))
    (reduce add 0 values)))

(proc threaded-first [] -> int
  (let [xs (new []int [1 2 3 4])
        threaded (->> xs
                      (remove even?)
                      (map-indexed add-index)
                      (reverse))]
    (defer (delete threaded))
    (first threaded)))

(proc main []
  (fmt.println (age-for-grace)))

(comment
  (split-front-length)
  ;; => 2

  (first-kept-square)
  ;; => 4

  (age-for-grace)
  ;; => 45

  (chunk-count)
  ;; => 2

  (repeated-two-count)
  ;; => 2

  (indexed-name-count)
  ;; => 3

  (even-group-count)
  ;; => 3

  (range-total)
  ;; => 10

  (repeated-answer-count)
  ;; => 3

  (repeated-word-last)
  ;; => odin

  (iterated-last)
  ;; => 8

  (cycled-total)
  ;; => 9

  (counted-cycle)
  ;; => 5

  (trimmed-sum)
  ;; => 13

  (rest-second-empty-score)
  ;; => 40

  (concat-reversed-first)
  ;; => 4

  (sorted-second)
  ;; => 2

  (descending-first)
  ;; => 4

  (sorted-in-place-first)
  ;; => 1

  (reversed-in-place-first)
  ;; => 4

  (descending-in-place-first)
  ;; => 4

  (doubled-in-place-total)
  ;; => 12

  (indexed-in-place-second)
  ;; => 3

  (filtered-in-place-count)
  ;; => 2

  (removed-in-place-first)
  ;; => 1

  (kept-in-place-first)
  ;; => 4

  (appended-total)
  ;; => 10

  (distinct-total)
  ;; => 6

  (first-per-parity-count)
  ;; => 2

  (ragged-chunk-size)
  ;; => 1

  (run-count)
  ;; => 4

  (flattened-total)
  ;; => 15

  (threaded-first)
  ;; => 4
)
