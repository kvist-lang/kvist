// Hiccup supports a small typed value surface for attrs and text nodes.
(package main)
(import hiccup "kvist:hiccup")

(defn values-demo [] -> bool
  (let [page (hiccup/html
               [:section {:hidden false :data-count 3 :data-ratio 1.5}
                [:h1 "Report"]
                [:p true]
                [:p 42]
                [:p 3.25]])
        html (hiccup/render page) defer]
    (core/println html)
    true))

(defn main []
  (values-demo))
