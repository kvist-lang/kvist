// Non-mutating updates for plain struct values.
(package main)
(import core "kvist:core")

(defstruct Profile {
  name: string
})

(defstruct User {
  profile: Profile
  age: int
  active?: bool
})

(defn inc [x: int] -> int
  (+ x 1))

(defn add-years [age: int, years: int] -> int
  (+ age years))

(defn birthday [user: User] -> User
  (update user.age inc))

(defn rename [user: User, name: string] -> User
  (assoc user.profile.name name))

(defn retire [user: User] -> User
  (-> user
    (update .age + 30)
    (assoc .profile.name "Ada Lovelace")
    (assoc .active? false)))

(defn score [] -> int
  (let [ada (User {profile: (Profile {name: "Ada"}) age: 36 active?: true})
        older (birthday ada)
        named (rename older "Ada Lovelace")
        retired (retire named)]
    (+ ada.age older.age retired.age (len retired.profile.name))))

(defn main []
  (println (score)))

(comment
  (score)
  ;; => 152
)
