// Close port of the Cluck reset docs demo.
(package main)
(import core "kvist:core")
(def docs_banner
  "Banner used by the docs demo."
  "doc demo")

(defn docs-demo
  "Show doc lookup for both value and function declarations."
  [] -> bool
  (core.println docs_banner)
  (core.doc 'docs_banner)
  (core.doc 'docs_demo)
  true)

(defn main []
  (core.println (docs-demo)))

(core.comment
  (docs-demo))
