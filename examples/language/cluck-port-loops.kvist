// Close port of the Cluck reset loop demos.
(package main)
(import arr "kvist:arr")

(defn loop-index-demo [] -> [dynamic]int
  (let [xs (arr/dynamic int [10 20 30]) defer
        out (arr/empty int)]
    (each [i x xs]
      (arr/push! out (+ x i)))
    out))

(defn loop-break-demo [] -> int
  (let [xs (arr/dynamic int [3 5 8 13 21]) defer
        found 0]
    (each [x xs]
      (core/when (> x 10)
        (set! found x)
        (break)))
    found))

(defn loop-continue-demo [] -> [dynamic]int
  (let [xs (arr/dynamic int [0 1 2 3 4 5]) defer
        out (arr/empty int)]
    (each [x xs]
      (core/when (== 0 (% x 2))
        (continue))
      (arr/push! out x))
    out))

(defn main []
  (let [indexed (loop-index-demo) defer
        continued (loop-continue-demo) defer]
    (core/println indexed)
    (core/println (loop-break-demo))
    (core/println continued)))

(core/comment
  (loop-index-demo)
  (loop-break-demo)
  (loop-continue-demo))
