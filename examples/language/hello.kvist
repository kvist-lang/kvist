// Greets from Kvist.
(package main)

;; This is a greeting
(defstruct Greeting {
  message: string
})

(defn main []
  (let [g (Greeting { message: "hello from kvist" })]
    (println g.message)))

(comment

  (-> (Greeting { message: "hello!" })
      .message
      len)
  ;; => 6

)
