// Explicit tap-style inspection for eval-driven development.
(package main)
(import arr "kvist:arr")

(defstruct User {
  :name string
  :age int
})

(defn inspected-age [] -> int
  (let [user (tap> :user (User {:name "Ada" :age 36}))
        age (tap> :age (:age user))]
    age))

(defn inspected-owned-count [] -> int
  (let [xs (tap> "numbers" (arr/dynamic int [1 2 3]))]
    (defer (delete xs))
    (count xs)))

(defn plus-one [x: int] -> int
  (+ x 1))

(defn even? [x: int] -> bool
  (== (% x 2) 0))

(defn add [acc: int, x: int] -> int
  (+ acc x))

(defn inspected-thread-total [] -> int
  (let [xs (arr/dynamic int [1 2 3 4])
        total (->> xs
                   (map plus-one)
                   (tap> :mapped)
                   (filter even?)
                   (reduce add 0))]
    (defer (delete xs))
    total))

(defn main []
  (println (inspected-age))
  (println (inspected-thread-total)))

(comment
  (inspected-age)
  ;; prints:
  ;; user: User{name = "Ada", age = 36}
  ;; age: 36
  ;; => 36

  (inspected-owned-count)
  ;; prints:
  ;; numbers: [1, 2, 3]
  ;; => 3

  (inspected-thread-total)
  ;; prints:
  ;; mapped: [2, 3, 4, 5]
  ;; => 6
)
