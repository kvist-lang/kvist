(package reload_step_demo)

(import time "core:time")
(import reload "kvist:reload")

(defstruct Program_State
  {jobs-finished: int
   last-status: string})

(defstruct App_State
  {program: Program_State
   step-count: int
   reload-count: int
   unload-count: int})

(def Reload_State App_State)
(def Reload_Version "v1")

(def delay: time.Duration (* 1 time.Second))

(defn init [state: ^Reload_State]
  (init-program &state^.program))

(defn on-load [state: ^Reload_State is-reload: bool]
  (when is-reload
    (mut! state^.reload-count += 1)))

(defn on-unload [state: ^Reload_State]
  (mut! state^.unload-count += 1))

(defn step [state: ^Reload_State]
  (mut! state^.step-count += 1)
  (run-one-step &state^.program)
  (print-status state^.step-count
                state^.reload-count
                state^.unload-count
                &state^.program))

(defn run [state: ^Reload_State host: ^reload.Run_Host]
  (while true
    (step state)
    (time.sleep delay)
    (when (reload.checkpoint! host)
      (return))))
