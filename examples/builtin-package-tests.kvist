(package tests)

(import t "kvist:test")
(import arr "kvist:arr")
(import io "kvist:io")
(import json "kvist:json")
(import map "kvist:map")
(import set "kvist:set")
(import str "kvist:str")
(import struct "kvist:struct")
(import os "core:os")

(defstruct Profile {
  :name string
  :age int
})

(defstruct Note {
  :title string
  :body string
})

(defn inc-value [x: int] -> int
  (+ x 1))

(defn even-value? [x: int] -> bool
  (== (% x 2) 0))

(defn add-values [acc: int, x: int] -> int
  (+ acc x))

(defn query-positive [x: int] -> [value: int, ok: bool] #optional_ok
  (if (> x 0)
    (return x true)
    (return 0 false)))

(defn ensure-test-dir [] -> os.Error
  (let [err (os.make_directory_all "tmp")]
    (if (and (!= err nil)
             (not (os.is_directory "tmp")))
      err
      nil)))

(t/deftest core-package-surface
  (let [xs [1 2 3 4] defer
        lookup (map/of string int {"a" 1 "b" 2}) defer
        mutable (new [dynamic]int [1 2 3]) defer
        prefix (slice xs 1 3)]
    (update! mutable 1 9)
    (t/is (= (count xs) 4))
    (t/is (= (get xs 0) 1))
    (t/is (= (count prefix) 2))
    (t/is (= (get prefix 0) 2))
    (t/is (= (map/get lookup "a" 0) 1))
    (t/is (= (or-else (query-positive 7) 0) 7))
    (t/is (= (or-else (query-positive -1) 9) 9))
    (t/is (= (get mutable 1) 9))))

(t/deftest arr-package-surface
  (let [xs (arr/range 1 6) defer
        mapped (arr/map inc-value (slice xs 0)) defer
        filtered (arr/filter even-value? (slice xs 0)) defer
        removed (arr/remove even-value? (slice xs 0)) defer
        repeated (arr/repeat 3 9) defer
        mutable (arr/dynamic int [1 2 3]) defer]
    (arr/map! inc-value mutable)
    (arr/filter! even-value? mutable)
    (arr/push! mutable 8)
    (t/is (= (count xs) 5))
    (t/is (= (arr/first xs) 1))
    (t/is (= (arr/last xs) 5))
    (t/is (= (get mapped 0) 2))
    (t/is (= (count filtered) 2))
    (t/is (= (count removed) 3))
    (t/is (= (arr/reduce add-values 0 (slice xs 0)) 15))
    (t/is (= (count repeated) 3))
    (t/is (= (get mutable 0) 2))
    (t/is (= (get mutable (- (count mutable) 1)) 8))))

(t/deftest map-package-surface
  (let [base (map/of string int {"a" 1 "b" 2}) defer
        overrides (map/of string int {"b" 20 "c" 30}) defer
        merged (map/merge base overrides) defer
        assoced (map/assoc merged "z" 99) defer
        trimmed (map/dissoc assoced "b") defer
        key-list (map/keys merged) defer
        value-list (map/vals merged) defer
        zip-keys (arr/dynamic string ["x" "y" "z"]) defer
        zip-vals (arr/dynamic int [10 20]) defer
        zipped (map/zip (slice zip-keys 0) (slice zip-vals 0)) defer
        mutable (map/of string int {"seed" 1}) defer
        fresh (map/empty string int 2) defer]
    (update! fresh "alpha" 11)
    (map/assoc! mutable "extra" 7)
    (map/dissoc! mutable "seed")
    (map/merge! mutable overrides)
    (t/is (= (map/get base "a" 0) 1))
    (t/is (= (map/get merged "c" 0) 30))
    (t/is (map/contains? merged "a"))
    (t/is (= (map/get assoced "z" 0) 99))
    (t/is (= (map/get trimmed "b" 0) 0))
    (t/is (= (count key-list) 3))
    (t/is (= (count value-list) 3))
    (t/is (= (map/get zipped "x" 0) 10))
    (t/is (= (map/get zipped "z" 99) 99))
    (t/is (= (map/get fresh "alpha" 0) 11))
    (t/is (= (map/get mutable "extra" 0) 7))
    (t/is (= (map/get mutable "c" 0) 30))))

(t/deftest set-package-surface
  (let [lhs (set/of int [1 2 3]) defer
        rhs (set/of int [3 4]) defer
        unioned (set/union lhs rhs) defer
        intersected (set/intersection lhs rhs) defer
        differed (set/difference lhs rhs) defer
        bigger (set/add lhs 9) defer
        smaller (set/remove bigger 2) defer
        mutable (set/of int [1 2 3]) defer
        removed (set/of int [2]) defer]
    (set/add! mutable 5)
    (set/remove! mutable 1)
    (set/union! mutable rhs)
    (set/difference! mutable removed)
    (t/is (set/contains? unioned 4))
    (t/is (set/contains? intersected 3))
    (t/is (not (set/contains? intersected 1)))
    (t/is (set/contains? differed 1))
    (t/is (set/contains? bigger 9))
    (t/is (not (set/contains? smaller 2)))
    (t/is (set/subset? intersected unioned))
    (t/is (set/superset? unioned intersected))
    (t/is (set/disjoint? differed rhs))
    (t/is (= (get mutable 4 false) true))
    (t/is (= (get mutable 5 false) true))
    (t/is (= (get mutable 2 false) false))))

(t/deftest str-package-surface
  (let [name "  Kvist Core  "
        trimmed (str/trim name)
        without-prefix (str/trim-prefix "kvist/core" "kvist/")
        without-suffix (str/trim-suffix "kvist.txt" ".txt")
        starts? (str/starts-with? trimmed "K")
        ends? (str/ends-with? trimmed "re")
        parts (str/split "a,b,c" ",") defer
        joined (str/join parts "-") defer
        replaced (str/replace joined "-" "_") defer
        lowered (str/lower replaced) defer
        uppered (str/upper lowered) defer]
    (t/is (= (str/count trimmed) 10))
    (t/is (= (str/slice trimmed 0 5) "Kvist"))
    (t/is (str/contains? trimmed "Core"))
    (t/is (= without-prefix "core"))
    (t/is (= without-suffix "kvist"))
    (t/is starts?)
    (t/is ends?)
    (t/is (= (str/index-of joined "-") 1))
    (t/is (= (str/last-index-of joined "-") 3))
    (t/is (= joined "a-b-c"))
    (t/is (= replaced "a_b_c"))
    (t/is (= lowered "a_b_c"))
    (t/is (= uppered "A_B_C"))))

(t/deftest struct-package-surface
  (let [fields (struct/fields 'Profile)
        types (struct/types 'Profile) defer]
    (t/is (= (count fields) 2))
    (t/is (= (get fields 0) ":name"))
    (t/is (= (get fields 1) ":age"))
    (t/is (= (map/get types ":name" "") "string"))
    (t/is (= (map/get types ":age" "") "int"))))

(t/deftest io-and-json-package-surface
  (t/is (== (ensure-test-dir) nil))
  (let [text-path "tmp/builtin-package-tests.txt"
        json-path "tmp/builtin-package-tests.json"]
    (defer (os.remove text-path))
    (defer (os.remove json-path))
    (t/is (== (io/write text-path "hello kvist") nil))
    (let [[data read-err] (io/read text-path)]
      (defer (delete data))
      (t/is (== read-err nil))
      (t/is (= (string data) "hello kvist")))
    (let [[marshal-err write-err] (json/write json-path (Note {:title "hello" :body "world"}))]
      (t/is (== marshal-err nil))
      (t/is (== write-err nil)))
    (let [[note read-err unmarshal-err] (json/read-as Note json-path)]
      (defer (delete (:title note)))
      (defer (delete (:body note)))
      (t/is (== read-err nil))
      (t/is (== unmarshal-err nil))
      (t/is (= (:title note) "hello"))
      (t/is (= (:body note) "world")))))
