(package test)

(import "base:intrinsics")
(import core "kvist:core")
(import reflect "core:reflect")
(import "core:strings")
(import "core:sync")
(import "core:testing")

(odin "
__kvist_test_context_lock: sync.Mutex
__kvist_test_context_stacks: map[uintptr][dynamic]string

__kvist_test_context_cleanup :: proc(user_data: rawptr) {
	key := uintptr(user_data)

	sync.mutex_lock(&__kvist_test_context_lock)
	defer sync.mutex_unlock(&__kvist_test_context_lock)

	stack, ok := __kvist_test_context_stacks[key]
	if !ok {
		return
	}
	for msg in stack {
		delete(msg)
	}
	delete(stack)
	delete_key(&__kvist_test_context_stacks, key)
	if len(__kvist_test_context_stacks) == 0 {
		delete(__kvist_test_context_stacks)
	}
}

__kvist_test_context_prefix :: proc(t: ^testing.T) -> string {
	key := uintptr(t)

	sync.mutex_lock(&__kvist_test_context_lock)
	stack, ok := __kvist_test_context_stacks[key]
	if !ok || len(stack) == 0 {
		sync.mutex_unlock(&__kvist_test_context_lock)
		return \"\"
	}
	prefix, _ := strings.join(stack[:], \" > \", allocator=context.temp_allocator)
	sync.mutex_unlock(&__kvist_test_context_lock)
	return prefix
}

__kvist_test_push_context :: proc(t: ^testing.T, message: string) {
	key := uintptr(t)
	cloned, clone_err := strings.clone(message)
	assert(clone_err == nil, \"kvist:test could not clone t.testing message\")

	sync.mutex_lock(&__kvist_test_context_lock)
	defer sync.mutex_unlock(&__kvist_test_context_lock)

	stack, existed := __kvist_test_context_stacks[key]
	if !existed {
		testing.cleanup(t, __kvist_test_context_cleanup, rawptr(t))
	}
	append(&stack, cloned)
	__kvist_test_context_stacks[key] = stack
}

__kvist_test_pop_context :: proc(t: ^testing.T) {
	key := uintptr(t)

	sync.mutex_lock(&__kvist_test_context_lock)
	defer sync.mutex_unlock(&__kvist_test_context_lock)

	stack, ok := __kvist_test_context_stacks[key]
	if !ok || len(stack) == 0 {
		return
	}
	delete(stack[len(stack)-1])
	resize(&stack, len(stack)-1)
	__kvist_test_context_stacks[key] = stack
}

__kvist_test_expect :: proc(t: ^testing.T, ok: bool, msg := \"\", expr := #caller_expression(ok), loc := #caller_location) -> bool {
	if ok {
		return true
	}
	prefix := __kvist_test_context_prefix(t)
	if prefix == \"\" {
		return testing.expect(t, ok, msg, expr=expr, loc=loc)
	}
	if msg == \"\" {
		return testing.expectf(t, ok, \"%s: expected %v to be true\", prefix, expr, loc=loc)
	}
	return testing.expectf(t, ok, \"%s: %s\", prefix, msg, loc=loc)
}

__kvist_test_expect_value :: proc(t: ^testing.T, value, expected: $T, loc := #caller_location, value_expr := #caller_expression(value)) -> bool where intrinsics.type_is_comparable(T) {
	ok := value == expected || reflect.is_nil(value) && reflect.is_nil(expected)
	if ok {
		return true
	}
	prefix := __kvist_test_context_prefix(t)
	if prefix == \"\" {
		return testing.expect_value(t, value, expected, loc=loc, value_expr=value_expr)
	}
	return testing.expectf(t, ok, \"%s: expected %v to be %v, got %v\", prefix, value_expr, expected, value, loc=loc)
}

__kvist_test_once_guard: sync.Once
")

(defmacro- __kvist_test_wrap_each
  [body]
  body)

(defmacro- __kvist_test_wrap_once
  [body]
  body)

(defmacro- emit-fixture-chain
  [body fixtures]
  (if (= (core.count fixtures) 0)
    body
    (quasiquote
      ((unquote (first fixtures)) t
       (fn [t: ^testing.T]
         (unquote (emit-fixture-chain body (rest fixtures))))))))

(defmacro- emit-once-fixtures
  [fixtures]
  (if (= (core.count fixtures) 0)
    (forms)
    (quasiquote
      (do
        ((unquote (first fixtures)))
        (splice (emit-once-fixtures (rest fixtures)))))))

(defmacro- emit-is
  [expr msg]
  (if (list? expr)
    (let [head (first expr)]
      (if (symbol? head)
        (if (= (name head) "=")
          (if (= (core.count expr) 3)
            (if (nil? msg)
              (if (field-selector? (nth expr 1))
                (quasiquote
                  (__kvist_test_expect t (= (unquote (nth expr 1)) (unquote (nth expr 2)))))
                (if (field-selector? (nth expr 2))
                  (quasiquote
                    (__kvist_test_expect t (= (unquote (nth expr 1)) (unquote (nth expr 2)))))
                  (quasiquote
                    (__kvist_test_expect_value t (unquote (nth expr 1)) (unquote (nth expr 2))))))
              (quasiquote
                (__kvist_test_expect t (= (unquote (nth expr 1)) (unquote (nth expr 2))) (unquote msg))))
            (error "t.is with = expects exactly two operands"))
          (if (= (name head) "not")
            (if (= (core.count expr) 2)
              (if (nil? msg)
                (quasiquote
                  (__kvist_test_expect t (not (unquote (nth expr 1)))))
                (quasiquote
                  (__kvist_test_expect t (not (unquote (nth expr 1))) (unquote msg))))
              (error "t.is with not expects exactly one operand"))
            (if (nil? msg)
              (quasiquote
                (__kvist_test_expect t (unquote expr)))
              (quasiquote
                (__kvist_test_expect t (unquote expr) (unquote msg))))))
        (if (nil? msg)
          (quasiquote
            (__kvist_test_expect t (unquote expr)))
          (quasiquote
            (__kvist_test_expect t (unquote expr) (unquote msg))))))
    (if (nil? msg)
      (quasiquote
        (__kvist_test_expect t (unquote expr)))
      (quasiquote
        (__kvist_test_expect t (unquote expr) (unquote msg))))))

(defmacro- emit-deftest
  [name doc body]
  (if (nil? doc)
    (forms
      (quasiquote (import "core:testing"))
      (quasiquote (attr test))
      (quasiquote
        (defn (unquote name) [t: ^testing.T]
          (unquote (__kvist_test_wrap_once
                     (__kvist_test_wrap_each
                       (quasiquote (do (splice body)))))))))
    (forms
      (quasiquote (import "core:testing"))
      (quasiquote (attr test))
      (quasiquote
        (defn (unquote name)
          (unquote doc)
          [t: ^testing.T]
          (unquote (__kvist_test_wrap_once
                     (__kvist_test_wrap_each
                       (quasiquote (do (splice body)))))))))))

(defmacro- emit-are
  [argv expr values]
  (let [n (core.count argv)
        row (core.slice values 0 n)
        remaining (core.slice values n)]
    (if (= (core.count values) 0)
      (forms)
      (if (= (core.count row) n)
        (quasiquote
          (do
            (is (unquote (subst expr argv row)))
            (splice (emit-are argv expr remaining))))
        (error "t.are expects a multiple of the binding count")))))

(defmacro deftest
  "Define an executable Kvist test.

  `(t.deftest name body...)` lowers to an Odin `@(test)` proc named `name` with a
  `^testing.T` parameter bound as `t` inside the body. A string immediately after
  the test name becomes the generated proc docstring:

  `(t.deftest parses-empty-input \"Empty input is valid.\" ...)`

  Tests should use `t.is` for assertions so failures are reported through Odin's
  testing package and include any active `t.testing` context."
  [name & body]
  (let [maybe-doc (first body)]
    (if (string? maybe-doc)
      (emit-deftest name maybe-doc (rest body))
      (emit-deftest name nil body))))

(defmacro is
  "Assert that `expr` is true, with an optional failure message.

  `(t.is expr)` records a test failure when `expr` is false. `(t.is expr
  \"message\")` uses the message in the failure report. Equality forms of shape
  `(= actual expected)` lower to Odin's value-aware expectation helper so reports
  include both values. Equality against implicit selectors such as `.OK` lowers
  as a boolean expression so Odin can infer the selector type; `(not expr)` also
  gets direct specialized lowering.

  `t.is` returns the boolean result from the underlying Odin assertion helper."
  [expr & rest]
  (if (= (core.count rest) 0)
    (emit-is expr nil)
    (if (= (core.count rest) 1)
      (emit-is expr (first rest))
      (error "t.is expects an expression and optional message"))))

(defmacro testing
  "Run `body` with an additional assertion context message.

  Nested `t.testing` forms are joined in failure output, so a failing assertion
  reports the path of surrounding contexts. The context is scoped with `defer`,
  and is removed even when the body returns early."
  [message & body]
  (quasiquote
    (do
      (__kvist_test_push_context t (unquote message))
      (defer (__kvist_test_pop_context t))
      (splice body))))

(defmacro are
  "Repeat one assertion template over rows of values.

  `argv` is a binding vector used inside `expr`. `values` are consumed in rows
  the same length as `argv`; each row substitutes into `expr` and expands to one
  `t.is` assertion. The number of values must be an exact multiple of the binding
  count.

  Example shape: `(t.are [x y] (= (+ x y) 10) 1 9 4 6)`."
  [argv expr & values]
  (if (= (core.count argv) 0)
    (error "t.are expects a non-empty binding vector")
    (emit-are argv expr values)))

(defmacro use-fixtures
  "Install fixtures for tests defined later in the same package file.

  `(t.use-fixtures each: f...)` wraps each test body in the listed fixtures.
  Each fixture is called as `(f t body-proc)`, where `body-proc` is a proc taking
  `^testing.T`.

  `(t.use-fixtures once: f...)` runs setup procs once before the first wrapped
  test body executes. Current `:once` fixtures are setup-only and do not receive
  a teardown continuation."
  [scope & fixtures]
  (if (= (name scope) "each")
    (let [template (emit-fixture-chain (quote __kvist_test_body__) fixtures)]
      (quasiquote
        (defmacro- __kvist_test_wrap_each
          [body]
          (subst (unquote template)
                 (vector (quote __kvist_test_body__))
                 (vector body)))))
    (if (= (name scope) "once")
      (let [setup (emit-once-fixtures fixtures)]
        (forms
          (quasiquote
            (defn- __kvist_test_run_once_fixtures []
              (unquote setup)))
          (quasiquote
            (defn- __kvist_test_ensure_once []
              (sync.once_do (& __kvist_test_once_guard) __kvist_test_run_once_fixtures)))
          (quasiquote
            (defmacro- __kvist_test_wrap_once
              [body]
              (quasiquote
                (do
                  (__kvist_test_ensure_once)
                  (unquote body)))))))
      (error "t.use-fixtures currently supports only each: and once:"))))
