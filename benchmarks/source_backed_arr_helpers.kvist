(proc bench-builders-intrinsic [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [numbers (pkgarr/range 1 N) defer
            sampled (pkgarr/take-nth 3 xs) defer
            repeated (pkgarr/repeat 8 9) defer
            generated (pkgarr/repeatedly 8 always-seven) defer
            powers (pkgarr/iterate 8 double 1) defer
            cycled (pkgarr/cycle 9 xs) defer]
        (set! checksum (+ checksum (arr/last numbers)))
        (set! checksum (+ checksum (arr/last sampled)))
        (set! checksum (+ checksum (arr/last repeated)))
        (set! checksum (+ checksum (arr/last generated)))
        (set! checksum (+ checksum (arr/last powers)))
        (set! checksum (+ checksum (arr/last cycled))))
      (set! i (+ i 1)))
    checksum))

(proc bench-builders-source [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [numbers (pkgarr/range 1 N) defer
            sampled (pkgarr/take-nth 3 xs) defer
            repeated (pkgarr/repeat 8 9) defer
            generated (pkgarr/repeatedly 8 always-seven) defer
            powers (pkgarr/iterate 8 double 1) defer
            cycled (pkgarr/cycle 9 xs) defer]
        (set! checksum (+ checksum (pkgarr/last numbers)))
        (set! checksum (+ checksum (pkgarr/last sampled)))
        (set! checksum (+ checksum (pkgarr/last repeated)))
        (set! checksum (+ checksum (pkgarr/last generated)))
        (set! checksum (+ checksum (pkgarr/last powers)))
        (set! checksum (+ checksum (pkgarr/last cycled))))
      (set! i (+ i 1)))
    checksum))

(proc bench-scan-intrinsic [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [prefix (arr/take-while below-cutoff? xs)
            suffix (arr/drop-while below-cutoff? xs)
            [first-hit ok] (arr/find divisible-by-three? suffix)
            any? (arr/some? divisible-by-three? suffix)
            all? (arr/every? below-cutoff? prefix)]
        (set! checksum (+ checksum (count prefix)))
        (set! checksum (+ checksum (count suffix)))
        (when ok
          (set! checksum (+ checksum first-hit)))
        (when any?
          (set! checksum (+ checksum 1)))
        (when all?
          (set! checksum (+ checksum 1))))
      (set! i (+ i 1)))
    checksum))

(proc bench-scan-source [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [prefix (pkgarr/take-while below-cutoff? xs)
            suffix (pkgarr/drop-while below-cutoff? xs)
            [first-hit ok] (pkgarr/find divisible-by-three? suffix)
            any? (pkgarr/some? divisible-by-three? suffix)
            all? (pkgarr/every? below-cutoff? prefix)]
        (set! checksum (+ checksum (count prefix)))
        (set! checksum (+ checksum (count suffix)))
        (when ok
          (set! checksum (+ checksum first-hit)))
        (when any?
          (set! checksum (+ checksum 1)))
        (when all?
          (set! checksum (+ checksum 1))))
      (set! i (+ i 1)))
    checksum))

(proc bench-reorder-intrinsic [xs: []int, ys: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [reversed (pkgarr/reverse xs) defer
            interposed (pkgarr/interpose 0 xs) defer
            interleaved (pkgarr/interleave xs ys) defer]
        (set! checksum (+ checksum (pkgarr/get reversed 0)))
        (set! checksum (+ checksum (pkgarr/get interposed 1)))
        (set! checksum (+ checksum (pkgarr/get interleaved 1)))
        (set! checksum (+ checksum (count reversed)))
        (set! checksum (+ checksum (count interposed)))
        (set! checksum (+ checksum (count interleaved))))
      (set! i (+ i 1)))
    checksum))

(proc bench-reorder-source [xs: []int, ys: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [reversed (pkgarr/reverse xs) defer
            interposed (pkgarr/interpose 0 xs) defer
            interleaved (pkgarr/interleave xs ys) defer]
        (set! checksum (+ checksum (pkgarr/get reversed 0)))
        (set! checksum (+ checksum (pkgarr/get interposed 1)))
        (set! checksum (+ checksum (pkgarr/get interleaved 1)))
        (set! checksum (+ checksum (count reversed)))
        (set! checksum (+ checksum (count interposed)))
        (set! checksum (+ checksum (count interleaved))))
      (set! i (+ i 1)))
    checksum))

(proc bench-remove-at-source [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0
        mid (/ (count xs) 2)]
    (for (< i reps)
      (let [ordered (pkgarr/remove-ordered-at xs mid) defer
            unordered (pkgarr/remove-unordered-at xs mid) defer]
        (set! checksum (+ checksum (count ordered)))
        (set! checksum (+ checksum (pkgarr/get ordered mid)))
        (set! checksum (+ checksum (count unordered)))
        (set! checksum (+ checksum (pkgarr/get unordered mid))))
      (set! i (+ i 1)))
    checksum))

(proc bench-remove-at-bang-source [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0
        mid (/ (count xs) 2)]
    (for (< i reps)
      (let [ordered (pkgarr/empty int (count xs)) defer
            unordered (pkgarr/empty int (count xs)) defer]
        (odin "append(&ordered, ..xs)")
        (odin "append(&unordered, ..xs)")
        (pkgarr/remove-ordered-at! ordered mid)
        (pkgarr/remove-unordered-at! unordered mid)
        (set! checksum (+ checksum (count ordered)))
        (set! checksum (+ checksum (pkgarr/get ordered mid)))
        (set! checksum (+ checksum (count unordered)))
        (set! checksum (+ checksum (pkgarr/get unordered mid))))
      (set! i (+ i 1)))
    checksum))

(proc bench-partition-intrinsic [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [chunks (arr/partition 64 xs) defer
            chunks-all (arr/partition-all 64 xs) defer]
        (set! checksum (+ checksum (count chunks)))
        (set! checksum (+ checksum (count chunks-all)))
        (set! checksum (+ checksum (count (pkgarr/get chunks 0))))
        (set! checksum (+ checksum (count (pkgarr/get chunks-all (- (count chunks-all) 1))))))
      (set! i (+ i 1)))
    checksum))

