(proc bench-group-by-intrinsic [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [groups (arr/group-by parity xs)]
        (defer
          (for [_ group groups]
            (delete group))
          (delete groups))
        (set! checksum (+ checksum (odin "len(groups)")))
        (set! checksum (+ checksum (odin "len(groups[0])")))
        (set! checksum (+ checksum (odin "len(groups[1])"))))
      (set! i (+ i 1)))
    checksum))

