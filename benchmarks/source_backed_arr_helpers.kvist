(proc main []
  (let [old-allocator context.allocator
        xs (pkgarr/range 1 N)
        ys (pkgarr/range N (* N 2))
        reversed (pkgarr/reverse (slice xs 0))
        track: mem.Tracking-Allocator (odin "mem.Tracking_Allocator{}")]
    (defer (delete xs))
    (defer (delete ys))
    (defer (delete reversed))
