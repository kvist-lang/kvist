(proc bench-sort-intrinsic [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [sorted (arr/sort xs) defer
            mutable (arr/empty int (count xs)) defer]
        (odin "append(&mutable, ..xs)")
