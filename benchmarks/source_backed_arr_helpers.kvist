        (set! checksum (+ checksum (pkgarr/get sorted 0)))
        (set! checksum (+ checksum (pkgarr/last sorted)))
        (set! checksum (+ checksum (pkgarr/get mutable 0)))
        (set! checksum (+ checksum (pkgarr/last mutable))))
      (set! i (+ i 1)))
