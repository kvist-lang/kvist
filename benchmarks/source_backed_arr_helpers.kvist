// Focused benchmark for intrinsic vs source-backed kvist:arr helpers.
(package main)
(import arr "kvist:arr")
(import pkgarr "kvist:arr")
(import "core:fmt")
(import mem "core:mem")
(import time "core:time")

(odin "N :: 50_000
REPS :: 80
SCAN_REPS :: 400
BUILDER_REPS :: 60
KEEP_REPS :: 220
MAP_BANG_REPS :: 220
FILTER_BANG_REPS :: 220
KEEP_BANG_REPS :: 220
REMOVE_REPS :: 300
REORDER_REPS :: 120
PARTITION_REPS :: 300
PARTITION_BY_REPS :: 120
FREQUENCIES_REPS :: 220
INDEX_BY_REPS :: 220
GROUP_BY_REPS :: 120
COUNT_BY_REPS :: 220
SUM_BY_REPS :: 220
DISTINCT_REPS :: 120
DISTINCT_BY_REPS :: 220
SORT_REPS :: 80
SHUFFLE_REPS :: 160")

(proc inc-value [x: int] -> int
  (+ x 1))

(proc even-value? [x: int] -> bool
  (== (% x 2) 0))

(proc keep-even [x: int] -> [value: int, ok: bool]
  (if (even-value? x)
    (return x true)
    (return 0 false)))

(proc divisible-by-three? [x: int] -> bool
  (== (% x 3) 0))

(proc parity [x: int] -> int
  (% x 2))

(proc add-values [acc: int, x: int] -> int
  (+ acc x))

(proc double [x: int] -> int
  (* x 2))

(proc always-seven [] -> int
  7)

(proc pick-first [n: int] -> int
  0)

(proc below-cutoff? [x: int] -> bool
  (< x (/ N 2)))

(proc report [name: string, elapsed: time.Duration, checksum: int, track: ^mem.Tracking-Allocator]
  (fmt.printfln "%-19s %9.3f ms allocs=%8v total=%10v peak=%9v live=%v checksum=%v"
                name
                (time.duration_milliseconds elapsed)
                track.total-allocation-count
                track.total-memory-allocated
                track.peak-memory-allocated
                track.current-memory-allocated
                checksum))

(proc run-one [name: string, checksum: int, start: time.Tick, track: ^mem.Tracking-Allocator]
  (report name (time.tick-since start) checksum track))

(proc bench-pipe-intrinsic [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [mapped (arr/map inc-value xs) defer
            filtered (arr/filter even-value? mapped) defer
            removed (arr/remove divisible-by-three? filtered) defer
            total (arr/reduce add-values 0 removed)]
        (set! checksum (+ checksum total)))
      (set! i (+ i 1)))
    checksum))

(proc bench-pipe-source [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [mapped (pkgarr/map inc-value xs) defer
            filtered (pkgarr/filter even-value? mapped) defer
            removed (pkgarr/remove divisible-by-three? filtered) defer
            total (pkgarr/reduce add-values 0 removed)]
        (set! checksum (+ checksum total)))
      (set! i (+ i 1)))
    checksum))

(proc bench-pipe-fused [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [total 0]
        (for [x xs]
          (let [mapped (inc-value x)]
            (when (and (even-value? mapped)
                       (not (divisible-by-three? mapped)))
              (set! total (+ total mapped)))))
        (set! checksum (+ checksum total)))
      (set! i (+ i 1)))
    checksum))

(proc bench-keep-intrinsic [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [kept (arr/keep keep-even xs) defer]
        (set! checksum (+ checksum (count kept)))
        (set! checksum (+ checksum (pkgarr/get kept 0)))
        (set! checksum (+ checksum (pkgarr/last kept))))
      (set! i (+ i 1)))
    checksum))

(proc bench-keep-source [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [kept (pkgarr/keep keep-even xs) defer]
        (set! checksum (+ checksum (count kept)))
        (set! checksum (+ checksum (pkgarr/get kept 0)))
        (set! checksum (+ checksum (pkgarr/last kept))))
      (set! i (+ i 1)))
    checksum))

(proc bench-map!-intrinsic [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (for (< i reps)
      (let [mutable (arr/empty int (count xs)) defer]
        (odin "append(&mutable, ..xs)")
        (arr/map! inc-value mutable)
        (set! checksum (+ checksum (pkgarr/get mutable 0)))
        (set! checksum (+ checksum (pkgarr/last mutable))))
      (set! i (+ i 1)))
    checksum))

