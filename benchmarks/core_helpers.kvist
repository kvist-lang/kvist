// Focused benchmark for canonical bare core-helper lowering vs direct Odin.
(package main)
(import arr "kvist:arr")
(import fmt "core:fmt")
(import mem "core:mem")
(import time "core:time")

(odin "N :: 50_000
REPS :: 400
KEY_COUNT :: 20_000
STRIDE :: 7")

(defn report [name: string, elapsed: time.Duration, checksum: int, track: ^mem.Tracking-Allocator]
  (fmt.printfln "%-17s %9.3f ms allocs=%8v total=%10v peak=%9v live=%v checksum=%v"
                name
                (time.duration-milliseconds elapsed)
                track.total-allocation-count
                track.total-memory-allocated
                track.peak-memory-allocated
                track.current-memory-allocated
                checksum))

(defn run-one [name: string, checksum: int, start: time.Tick, track: ^mem.Tracking-Allocator]
  (report name (time.tick-since start) checksum track))

(defn build-ints [n: int] -> [dynamic]int
  (let [xs (arr.empty int n)
        i 0]
    (while (< i n)
      (arr.push! xs i)
      (set! i (+ i 1)))
    xs))

(defn build-keys [n: int] -> [dynamic]int
  (let [keys (arr.empty int n)
        i 0]
    (while (< i n)
      (arr.push! keys (% (* i 13) N))
      (set! i (+ i 1)))
    keys))

(defn build-lookup [n: int] -> map[int]int
  (let [lookup (map[int]int {})
        i 0]
    (while (< i n)
      (set! lookup[i] (* i 3))
      (set! i (+ i 1)))
    lookup))

(defn bench-index-core [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (while (< i reps)
      (let [j 0
            total 0
            n (count xs)]
        (while (< j n)
          (set! total (+ total xs[j]))
          (set! j (+ j STRIDE)))
        (set! checksum (+ checksum total)))
      (set! i (+ i 1)))
    checksum))

(defn bench-slice-core [xs: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (while (< i reps)
      (let [prefix xs[128:8192]
            suffix xs[8192:]
            total (+ (+ (count prefix) (count suffix))
                     (+ prefix[0] suffix[0]))]
        (set! checksum (+ checksum total)))
      (set! i (+ i 1)))
    checksum))

(defn bench-map-core [lookup: map[int]int, keys: []int, reps: int] -> int
  (let [i 0
        checksum 0]
    (while (< i reps)
      (let [j 0
            total 0
            n (count keys)]
        (while (< j n)
          (let [key keys[j]]
            (when (contains? lookup key)
              (set! total (+ total (get lookup key 0))))
            (set! total (+ total (get lookup (+ key N) -1))))
          (set! j (+ j 1)))
        (set! checksum (+ checksum total)))
      (set! i (+ i 1)))
    checksum))

(defn main []
  (let [xs (build-ints N)
        keys (build-keys KEY_COUNT)
        lookup (build-lookup N)
        old-allocator context.allocator
        track: mem.Tracking-Allocator (odin "mem.Tracking_Allocator{}")]
    (defer (delete xs))
    (defer (delete keys))
    (defer (delete lookup))
    (mem.tracking-allocator-init (& track) old-allocator old-allocator)
    (defer (mem.tracking-allocator-destroy (& track)))
    (set! context.allocator (mem.tracking-allocator (& track)))
    (defer (odin "context.allocator = old_allocator"))

    (mem.tracking-allocator-reset (& track))
    (let [start (time.tick-now)]
      (run-one "index-core" (bench-index-core xs[:] REPS) start (& track)))

    (mem.tracking-allocator-reset (& track))
    (let [start (time.tick-now)]
      (run-one "slice-core" (bench-slice-core xs[:] REPS) start (& track)))

    (mem.tracking-allocator-reset (& track))
    (let [start (time.tick-now)]
      (run-one "map-core" (bench-map-core lookup keys[:] REPS) start (& track)))))
